# This file needs to go in the Config directory to work
# Configure your environment variables, like data provider API keys, here
# example: KNDC_API_KEY_FMP=123456

# Financial Modeling Prep API key:
KNDC_API_KEY_FMP=

# LSEG Workspace API KEY
KNDC_API_KEY_LSEG=

# Banxico SIE token — Mexican macro series (free: https://www.banxico.org.mx/SieAPIRest/service/v1/token)
KNDC_API_KEY_BANXICO=

# INEGI token — Mexican macro series (free: https://www.inegi.org.mx/app/api/indicadores/interna_v1_1/tokenVerify.aspx)
KNDC_API_KEY_INEGI=

# FRED API key — US macro series (free: https://fredaccount.stlouisfed.org/apikey)
KNDC_API_KEY_FRED=
